# EduMind backend local environment.
# Copy this file to .env and replace placeholder secrets with real local values.

ENVIRONMENT=development
BACKEND_PORT=8000

# PostgreSQL container settings used by docker-compose.yml.
POSTGRES_USER=edumind
POSTGRES_PASSWORD=edumind_password_change_me
POSTGRES_DB=edumind
POSTGRES_PORT=5432

# Local non-Docker database URL. docker-compose.yml overrides DATABASE_URL for
# the backend container so it uses the postgres service name.
DATABASE_URL=postgresql://edumind:edumind_password_change_me@localhost:5432/edumind
DB_POOL_SIZE=20

# External API keys. Use real local development keys in .env only.
GROQ_API_KEY=replace-with-groq-api-key
TAVILY_API_KEY=replace-with-tavily-api-key

# Optional EduMind API key. Leave empty to disable legacy X-API-Key auth in dev.
EDUMIND_API_KEY=

# Browser/front-end origins allowed by backend CORS.
# Use a comma-separated list. Origins must include scheme + host + port.
# Do not use "*" in production because cookies and credentials are enabled.
#
# Local Vite defaults:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
#
# Vite network testing example. Replace 192.168.1.50 with your machine's LAN IP:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.50:5173
#
# Vercel frontend example:
# CORS_ORIGINS=https://your-vercel-app.vercel.app
#
# Future custom domain example:
# CORS_ORIGINS=https://edumind.ai,https://www.edumind.ai
DEV_AUTH_ENABLED=true

# Google OAuth and backend session cookie settings.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173
SESSION_SECRET_KEY=change-me-local-session-secret
SESSION_COOKIE_NAME=edumind_session
SESSION_MAX_AGE_SECONDS=604800

# Local vector/cache storage inside the backend container.
CHROMADB_PATH=/app/chromadb_data
RERANKER_ENABLED=false

# Groq models.
REASONING_MODEL=openai/gpt-oss-120b
GENERATION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
ADAPTATION_MODEL=openai/gpt-oss-120b
LESSON_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SMALL_TASK_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=120
GROQ_MAX_RETRIES=3

# Learning defaults.
MASTERY_THRESHOLD_FAST=0.60
MASTERY_THRESHOLD_MEDIUM=0.72
MASTERY_THRESHOLD_DEEP=0.85
DEFAULT_LESSON_MINUTES=10
DEFAULT_FATIGUE_THRESHOLD_MINUTES=25

# Evaluation scheduler/settings. Keep the background scheduler off by default
# for local Docker runs; set true when you intentionally want scheduled evals.
EVAL_ENABLED=false
EVAL_JUDGE_MODEL=llama-3.1-8b-instant
EVAL_EMBED_MODEL=all-MiniLM-L6-v2
EVAL_FAITHFULNESS_CLAIM_LIMIT=15
EVAL_PRECISION_K=10
EVAL_SCHEDULE_WEEKLY=true
EVAL_SCHEDULE_MONTHLY=true
EVAL_SCHEDULE_TIMEZONE=Asia/Kolkata

# ── OpenTelemetry distributed tracing (opt-in) ────────────────────────────────
# OFF by default: with OTEL_ENABLED=false no exporter is installed and every
# tracing code path is a zero-cost no-op — prod behaviour is unchanged. Set to
# true only for dev/demo profiling with Phoenix running (see
# monitoring/docker-compose.monitoring.yml). Exporter failures never break a
# request, so it is safe to enable even if Phoenix is temporarily down.
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:6006/v1/traces

